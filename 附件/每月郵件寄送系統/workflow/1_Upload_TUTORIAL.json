    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE part_time_main_info AS p\nSET \n    code_filter_flag = TRUE   -- 將篩選代碼旗標設為TRUE\nFROM project_code_info AS f\nWHERE p.project_code LIKE f.sql_filter\n  AND f.sql_filter IS NOT NULL\n  AND f.sql_filter != '';",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1104,
        672
      ],
      "id": "1efb4f40-b668-4f76-b74b-5922031f713c",
      "name": "篩選計畫代碼",
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "aGRtknH3a9AK2iqO",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- 一、重製 email_state_info (刪除所有資料並將 id 計數歸零)\nTRUNCATE TABLE email_state_info RESTART IDENTITY;\n\n-- 二、從 part_time_main_info 和 project_host_info 中找出對應助理和教授資訊並加入進 email_state_info 中\nINSERT INTO email_state_info (identity, name, email, project_code, project_name, is_send)\n-- 1. 助理資訊\n(\nSELECT DISTINCT ON (name, project_code)\n    '助理' AS identity,\n    name,\n    email,\n    project_code,\n    project_name,\n    FALSE AS is_send\nFROM part_time_main_info\nWHERE send_email_flag = TRUE\nORDER BY name, project_code\n)\n\nUNION ALL\n\n-- 2. 教授 (計畫主持人) 資訊\n(\nSELECT DISTINCT ON (ptmi.project_host, ptmi.project_code)\n    '教授' AS identity,\n    ptmi.project_host AS name,\n    phi.host_email AS email,\n    ptmi.project_code,\n    ptmi.project_name,\n    FALSE AS is_send\nFROM part_time_main_info ptmi\nLEFT JOIN project_host_info phi ON ptmi.project_host = phi.host_name\nWHERE ptmi.send_email_flag = TRUE\nORDER BY ptmi.project_host, ptmi.project_code\n);",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1456,
        672
      ],
      "id": "d760147a-69b6-41d0-8879-6c7d8bf85083",
      "name": "將寄送對象存入 email_state_info",
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "aGRtknH3a9AK2iqO",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- 1. [清理] 先將所有紀錄的 send_email_flag 重設為 FALSE，確保每次執行都是最新狀態\nUPDATE part_time_main_info\n  SET send_email_flag = FALSE;\n\n-- 2. [篩選與標記] 找出符合計畫名稱與日期規範的資料\nWITH month_boundaries AS \n(\n    SELECT \n        date_trunc('month', CURRENT_DATE)::date AS month_start,\n        (date_trunc('month', CURRENT_DATE) + interval '1 month - 1 day')::date AS month_end\n)\nUPDATE part_time_main_info AS ptmi\nSET \n    send_email_flag = TRUE\nFROM month_boundaries AS mb\nWHERE ptmi.code_filter_flag = TRUE          -- 條件 1：project_name 必須已有資料\n  AND ptmi.start_date <= mb.month_end       -- 條件 2：開始日期在今天之前\n  AND ptmi.end_date >= mb.month_start       -- 條件 3：結束日期落在本月之內",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
