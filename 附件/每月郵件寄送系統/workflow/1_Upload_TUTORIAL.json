    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// 處理計畫代碼與條件的組合\nconst formattedInput = items\n  .filter(item => \n    item.json.id != null && \n    item.json.raw_filter != null // 檢查實際存在的欄位\n  )\n  .map(item => {\n    // 範例格式：(id: 1, 條件: 109A開頭)\n    return `(id: ${item.json.id}, 條件: ${item.json.raw_filter})`;\n  })\n  .join(',');\n\nreturn [{ json: { gemini_input: formattedInput } }];"
      },
